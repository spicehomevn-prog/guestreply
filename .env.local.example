ANTHROPIC_API_KEY=sk-ant-...

# Access PIN — set the same value for both vars.
# NEXT_PUBLIC_ACCESS_PIN: client-side gate (baked into JS bundle at build time).
# ACCESS_PIN: server-side validation on every /api/reply request.
# Leave both empty to disable PIN protection (e.g. for local dev).
NEXT_PUBLIC_ACCESS_PIN=123456
ACCESS_PIN=123456
